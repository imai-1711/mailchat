                                         "text":  "={{ $json.bodyText }}",
                                         "options":  {
                                                         "appendAttribution":  false,
                                                         "attachments":  "={{ $json.attachmentNames }}",
                                                         "ccEmail":  "={{ $json.cc }}",
                                                         "bccEmail":  "={{ $json.bcc }}"
                                                     }
